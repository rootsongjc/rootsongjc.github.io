&lt;script&gt;
(function() {
  
  const detailsId = &#34;markmap-details-mindmap.md&#34;;
  const containerId = &#34;markmap-container-mindmap.md&#34;;
  const scriptContentId = &#34;markmap-md-content-mindmap.md&#34;;
  const svgRenderHeight = &#34;600px&#34;;

  const detailsElement = document.getElementById(detailsId);
  const containerElement = document.getElementById(containerId);
  const scriptTemplateElement = document.getElementById(scriptContentId);

  if (!detailsElement) {
    console.error(`Markmap: &lt;details&gt; element with ID &#34;${detailsId}&#34; not found.`);
    return;
  }
  if (!containerElement) {
    console.error(`Markmap: Container &lt;div&gt; with ID &#34;${containerId}&#34; not found.`);
    return;
  }
  if (!scriptTemplateElement) {
    console.error(`Markmap: Content \x3Cscript&gt; template with ID &#34;${scriptContentId}&#34; not found.`);
    return;
  }

  detailsElement.addEventListener(&#39;toggle&#39;, async function(event) {
    if (detailsElement.open &amp;&amp; !containerElement.markmapLoaded) {
      containerElement.markmapLoaded = true; 
      containerElement.classList.remove(&#39;markmap-hidden&#39;);
      containerElement.innerHTML = &#39;&lt;p style=&#34;text-align:center; padding: 20px; color: #555;&#34;&gt;Loading mind map...&lt;/p&gt;&#39;;

      
      setTimeout(async () =&gt; {
        try {
          
          
          const [{ Markmap }, toolbarMod, { Transformer }] = await Promise.all([
            import(&#39;https://cdn.skypack.dev/markmap-view@0.17.0&#39;),
            import(&#39;https://cdn.skypack.dev/markmap-toolbar@0.17.0&#39;),
            import(&#39;https://cdn.skypack.dev/markmap-lib@0.17.0&#39;)
          ]);
          const { load } = await import(&#39;https://cdn.skypack.dev/js-yaml&#39;);

          
          function parseFrontMatter(mdText) {
            if (typeof mdText !== &#39;string&#39;) {
                console.warn(&#39;Markmap: Markdown content is not a string.&#39;);
                return { content: &#39;&#39;, config: {} };
            }
            const text = mdText.trim();
            if (!text.startsWith(&#39;---&#39;)) {
              return { content: text, config: {} };
            }
            const lines = text.split(/\r?\n/);
            const endIdx = lines.findIndex((line, i) =&gt; i &gt; 0 &amp;&amp; line.trim() === &#39;---&#39;);

            if (endIdx === -1) {
              return { content: text, config: {} }; 
            }

            const yamlStr = lines.slice(1, endIdx).join(&#39;\n&#39;);
            const content = lines.slice(endIdx + 1).join(&#39;\n&#39;).trim();
            let config = {};
            try {
              config = load(yamlStr);
              if (config === null || typeof config !== &#39;object&#39;) { 
                config = {};
              }
            } catch (e) {
              console.error(&#39;Markmap: YAML parse error:&#39;, e);
              
            }
            return { content, config };
          }

          const markdownFullContent = scriptTemplateElement.textContent || scriptTemplateElement.innerHTML;
          if (!markdownFullContent || !markdownFullContent.trim()) {
            throw new Error(&#34;Markdown content is empty or could not be read from the template script tag.&#34;);
          }

          const { content: markdown, config: frontmatterConfig } = parseFrontMatter(markdownFullContent);

          if (!markdown.trim()) {
             throw new Error(&#34;Markdown content is empty after parsing front matter. Ensure your .md file has content after the front matter section (if any).&#34;);
          }

          const transformer = new Transformer();
          const { root, features } = transformer.transform(markdown);

          
          containerElement.innerHTML = &#39;&#39;;

          
          const svgElement = document.createElementNS(&#39;http://www.w3.org/2000/svg&#39;, &#39;svg&#39;);
          Object.assign(svgElement.style, {
            width: &#39;100%&#39;,
            height: svgRenderHeight,
            display: &#39;block&#39;,
            
          });
          containerElement.appendChild(svgElement);

          
          const markmapOptionsFromFM = (frontmatterConfig &amp;&amp; frontmatterConfig.markmap) ? frontmatterConfig.markmap : {};
          const initialExpandLevel = parseInt(markmapOptionsFromFM.initialExpandLevel ?? 2, 10);
          const colorFreezeLevel = markmapOptionsFromFM.colorFreezeLevel !== undefined
            ? Number(markmapOptionsFromFM.colorFreezeLevel)
            : undefined;

          const mmOptions = {
            initialExpandLevel: initialExpandLevel,
            duration: 500, 
            ...markmapOptionsFromFM, 
          };
          if (!isNaN(colorFreezeLevel)) {
            mmOptions.colorFreezeLevel = colorFreezeLevel;
          }

          const mm = Markmap.create(svgElement, mmOptions, root);
          containerElement.markmapInstance = mm; 
          

          
          if (toolbarMod &amp;&amp; toolbarMod.Toolbar) {
            const { Toolbar } = toolbarMod;
            const { el: toolbarElement } = Toolbar.create(mm);

            Object.assign(toolbarElement.style, {
              position: &#39;absolute&#39;,
              color: &#39;gray&#39;, 
              bottom: &#39;0.5rem&#39;,
              right: &#39;0.5rem&#39;,
              display: &#39;flex&#39;,
              flexDirection: &#39;row&#39;,
              border: &#34;1px solid #ccc&#34;,
              borderRadius: &#34;5px&#34;,
              padding: &#34;0.25rem&#34;,
              backgroundColor: &#34;rgba(255, 255, 255, 0.9)&#34; 
            });
            containerElement.style.position = &#39;relative&#39;; 
            containerElement.appendChild(toolbarElement);

            
            const brandElement = toolbarElement.querySelector(&#39;.mm-toolbar-brand&#39;);
            if (brandElement) {
              brandElement.style.display = &#39;none&#39;;
            }

            
            toolbarElement.querySelectorAll(&#39;.mm-toolbar-item&#39;).forEach(item =&gt; {
              item.style.transition = &#39;color .2s, background .2s&#39;;
              item.style.cursor = &#39;pointer&#39;;
              item.style.padding = &#39;0.2rem 0.4rem&#39;; 

              function updateActiveStyle() {
                if (item.classList.contains(&#39;active&#39;)) {
                  item.style.color = &#39;#007bff&#39;; 
                  item.style.background = &#39;#e6f0fa&#39;; 
                } else {
                  item.style.color = &#39;gray&#39;; 
                  item.style.background = &#39;transparent&#39;; 
                }
              }

              item.addEventListener(&#39;mouseenter&#39;, () =&gt; {
                if (!item.classList.contains(&#39;active&#39;)) {
                  item.style.color = &#39;#0056b3&#39;; 
                  item.style.background = &#39;#f0f8ff&#39;; 
                }
              });
              item.addEventListener(&#39;mouseleave&#39;, () =&gt; {
                updateActiveStyle(); 
              });
              
              updateActiveStyle(); 
            });
          }

        } catch (error) {
          console.error(&#34;Markmap rendering failed:&#34;, error);
            containerElement.innerHTML = `&lt;p style=&#34;color:red; text-align:center; padding:20px;&#34;&gt;Sorry, failed to load the mind map.&lt;br&gt;Error: ${error.message}&lt;br&gt;Please check the browser console for more technical details.&lt;/p&gt;`;
        }
      }, 50); 
    }
  });
})();
&lt;/script&gt;
&lt;p&gt;《镜花缘》是李汝珍所著的一部小说。故事发生在中国武则天（武后）称帝，改国号为周，年号光宅时期。虽然天下依靠唐朝的余荫大体无事，但武后尊崇武氏弟兄，荼毒唐朝子孙。&lt;/p&gt;
&lt;p&gt;故事主要围绕几条线索展开：&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;&lt;strong&gt;讨伐武后的尝试与后代传承&lt;/strong&gt;：英国公徐勣之孙徐敬业与骆宾王起兵讨伐武后，但兵败。徐敬业、骆宾王将年幼的儿子（徐承志、骆承志）托付给偏将保护逃脱，并留下血书和檄文，嘱咐他们日后务必协助主上复位，继承父志。血书分别送往陇右节度使史逸、淮南节度使文隐、河东节度使章更，这些人都素有勤王之意，但兵力不足。徐敬业最终被刺死，骆宾王下落不明。一些余党和家眷逃往海外。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;百花仙子的贬谪与百位才女的降生&lt;/strong&gt;：武后下旨命百花齐放，百花仙子因下棋耽误，未能及时奏请天帝，触犯了数百年前与嫦娥定下的罚约，被罚堕落红尘。后来，有一百位女性角色，她们是不同花仙子的转世。例如，百花仙子转世为唐闺臣。蜡梅花仙子转世为余丽蓉，人称“神弹子”。素馨花仙子转世为林婉如，人称“赛锺繇”。玉兰花仙子转世为司徒妩儿。这些才女贯穿了故事的后半部分。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;唐敖等人的海外游历&lt;/strong&gt;：故事的重要部分描写了唐敖、其妹夫林之洋（以经商为目的）、多九公（一位博学的长者）等人的海外旅行。唐敖本身是读书人，喜好游历，对功名已无心，沿途教侄女婉如诗赋。他们游历了许多奇特的国家，如：
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;君子国&lt;/strong&gt;：这里的居民以互相谦让为美德，买东西时买家想加价，卖家想减价，“好让不争”。多九公认为“好让不争”是邻邦所取。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;大人国&lt;/strong&gt;：居民脚下有云雾托着，行走不费力。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;黑齿国&lt;/strong&gt;：居民全身漆黑。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;女儿国&lt;/strong&gt;：林之洋在此被国王看中，被迫成亲，国王要他治河才肯放他回去。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;其他异国&lt;/strong&gt;：如蛰喙乡、智佳国等，他们也经历了遇到强盗（余丽蓉用弹弓相助）、多九公展示医术（治疗世子箭伤、王妃的病，并借机学习韵学秘术）、收养义女司徒妩儿 等事件。他们还遇到了奇特的阵法（如斗水关的酒阵、无火关的无火阵、巴刀关的巴刀阵），这些阵法有各自的规则和禁忌，触犯者会被困甚至丧命。&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;武则天开女科考试&lt;/strong&gt;：武后颁布诏书，设立女子科举考试，选拔有才华的女性担任官职。考试分为县考、郡考、部试、殿试，授予不同的称谓和官职（如“文学秀女”、“文学淑女”、“文学才女”、“女学士”、“女博士”、“女儒士”）。对考生及其家人也有相应的奖赏。一些因故错过考试的女子（如史幽探等十人）甚至获准特别补考。众多花仙子转世的才女参加了这次考试，并在殿试后获得了功名。她们在京城聚会，进行文学交流、诗词唱和、行酒令、猜谜等活动，展现了各自的才华和性格。&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;勤王复唐&lt;/strong&gt;：徐敬业和骆宾王的后代（徐承志、骆承志）以及文隐、章更等人的子侄辈（文芸、章荭等），联合了众多人物（共 34 位公子），起兵讨伐武后。这些公子及其妻子（共 35 位才女）共同参与军事行动。他们在行军过程中攻打关隘，如斗水关、无火关、巴刀关，并遭遇了奇异的阵法考验。章节列表显示最终勤王成功，唐中宗复位 [43, 第 100 回]。&lt;/li&gt;
&lt;/ol&gt;
&lt;p&gt;总的来说，《镜花缘》是一部融合了&lt;strong&gt;海外游记、神话仙幻、女性才华展示、社会批判&lt;/strong&gt;（如对科举制度、男尊女卑观念的探讨）以及&lt;strong&gt;勤王复辟&lt;/strong&gt;等元素的章回体小说。它通过唐敖等人的游历展现了作者对理想社会的想象以及对当时现实的反思，并以女性为主体展现了她们的学识和能力。&lt;/p&gt;

